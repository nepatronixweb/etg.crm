# ── Localhost (npm run dev) ───────────────────────────────────────────────────
# 1) Copy this file:  npm run setup:local
# 2) Set NEXTAUTH_SECRET below (openssl rand -base64 32)
# 3) Start MongoDB locally, then:  npm run seed   OR   npm run reset-admin
# 4) npm run dev  →  http://localhost:3000  (login: admin@etg.com / Admin@123 after seed/reset-admin)

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Atlas (cloud):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/etg-crm?retryWrites=true&w=majority
# VPS / local MongoDB on same machine:
MONGODB_URI=mongodb://127.0.0.1:27017/etg-crm
# If you change this while `npm run dev` is running, save again or restart dev — the app reconnects when the URI changes.

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
# Must match the URL you open in the browser (required for cookies / sign-in on localhost)
NEXTAUTH_URL=http://localhost:3000

# ── Vercel Blob ────────────────────────────────────────────────────────────────
# Auto-set by Vercel when you create a Blob store in Dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# ── Cron Security ─────────────────────────────────────────────────────────────
# Any random string — used to protect /api/cron/* endpoints
CRON_SECRET=your-cron-secret-here

# ── SMTP / Email ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password

# ── HR (Attendance / Salary) ───────────────────────────────────────────────────
# Office network IP seen by the app (often first hop in x-forwarded-for). If unset, IP check is skipped.
OFFICE_IP=
# Optional GPS fence (Haversine). If lat/lng env vars unset, distance check is skipped.
OFFICE_LAT=
OFFICE_LNG=
# Max distance from office in metres (default 500)
OFFICE_RADIUS_METERS=500
# IANA timezone for "today" (check-in date). Example: Asia/Dhaka
HR_TIMEZONE=UTC
