# ── MongoDB ───────────────────────────────────────────────────────────────────
# Atlas (cloud):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/etg-crm?retryWrites=true&w=majority
# VPS / local MongoDB on same machine:
MONGODB_URI=mongodb://127.0.0.1:27017/etg-crm

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
# Dev: http://localhost:3000 | VPS: http://YOUR_SERVER_IP or https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# ── Vercel Blob ────────────────────────────────────────────────────────────────
# Auto-set by Vercel when you create a Blob store in Dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# ── Cron Security ─────────────────────────────────────────────────────────────
# Any random string — used to protect /api/cron/* endpoints
CRON_SECRET=your-cron-secret-here

# ── SMTP / Email ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
